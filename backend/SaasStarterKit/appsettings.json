{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_YOUR_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "saas-starter-kit",
    "Audience": "saas-starter-kit-users",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "NpgSqlConnection": "Host=localhost;Port=5432;Database=saas_starter;Username=postgres;Password=REPLACE_WITH_YOUR_PASSWORD",
    "Redis": "localhost:6379"
  },
  "CacheSettings": {
    "DurationMinutes": 15
  },
  "ApiSettings": {
    "DefaultVersion": "1"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173,http://localhost:3000"
  }
}